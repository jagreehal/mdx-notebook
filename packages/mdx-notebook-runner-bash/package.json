{
  "name": "mdx-notebook-runner-bash",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./register": { "types": "./dist/register.d.ts", "import": "./dist/register.js" },
