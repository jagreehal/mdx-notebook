{
  "name": "mdx-notebook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test --concurrency=4",
    "test:watch": "turbo run test:watch --parallel --concurrency=4",
    "test:unit": "vitest run",
    "test:stories": "vitest run --config vitest.stories.config.ts",
    "test:e2e": "env -u NO_COLOR PLAYWRIGHT_HTML_OPEN=never playwright test",
    "test:all": "pnpm run typecheck && pnpm run test && pnpm run test:stories && pnpm run test:e2e",
    "typecheck": "turbo run typecheck --concurrency=4",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.0",
    "tsdown": "^0.12.0",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "executable-stories-vitest": "^8.1.16",
    "executable-stories-playwright": "^8.2.11",
    "@playwright/test": "^1.49.0"
  }
}
