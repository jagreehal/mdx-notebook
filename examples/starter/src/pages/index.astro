---
import Layout from "../components/Layout.astro";
import CopyButton from "../components/CopyButton.tsx";
import { getLessonsByGroup } from "../tutorials.config.ts";

const grouped = getLessonsByGroup().filter((g) => g.lessons.length > 0);
---
<Layout title="mdx-notebook — runnable docs">
  <section style="padding: 2rem 0 1rem;">
    <h1 style="font-size: 2.75rem; line-height: 1.1; margin-bottom: 1rem;">Runnable docs that don't go stale.</h1>
    <p style="font-size: 1.15rem; color: var(--fg-muted); max-width: 56ch; margin-bottom: 2rem;">
      Write MDX. Code runs at build time. Outputs are typed and bound to React components by id.
      Viewers can edit the captured data in their browser; components re-render. No server, no kernel.
    </p>
    <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
      <div style="display: flex; align-items: stretch; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; font-family: var(--font-mono); font-size: 0.92rem;">
        <span style="padding: 0.6rem 0.9rem;">npm create mdx-notebook my-tutorial</span>
        <CopyButton client:visible value="npm create mdx-notebook my-tutorial" />
      </div>
      <a href="https://github.com/jagreehal/mdx-notebook" style="padding: 0.6rem 1rem; border: 1px solid var(--border); border-radius: var(--radius-md); color: var(--fg); font-weight: 500;">View on GitHub</a>
    </div>
  </section>

  {grouped.map((g) => (
    <section style="margin-top: 3rem;">
      <h2 style="margin-top: 0;">{g.group.name}</h2>
      {g.group.description && (
        <p style="color: var(--fg-muted); margin-bottom: 1rem;">{g.group.description}</p>
      )}
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
        {g.lessons.map((l) => (
          <a href={`/tutorials/${l.slug}`} style="display: block; padding: 1.25rem; border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--bg); transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease; text-decoration: none; color: var(--fg);" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='var(--shadow-md)'; this.style.borderColor='var(--border-strong)';" onmouseout="this.style.transform=''; this.style.boxShadow=''; this.style.borderColor='var(--border)';">
            <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.4rem;">
              <div style="font-weight: 600; font-size: 1.05rem;">{l.title}</div>
              {l.durationMin && <span style="font-size: 0.78rem; color: var(--fg-muted);">{l.durationMin} min</span>}
            </div>
            {l.blurb && <div style="color: var(--fg-muted); font-size: 0.92rem; line-height: 1.5;">{l.blurb}</div>}
          </a>
        ))}
      </div>
    </section>
  ))}
</Layout>
