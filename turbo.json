{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:watch": { "cache": false, "persistent": true },
    "typecheck": { "dependsOn": ["^build"] },
    "clean": { "cache": false }
  }
}
